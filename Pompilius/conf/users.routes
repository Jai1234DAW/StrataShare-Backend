###
#  summary: Get user avatar
#  roles: {"required": "none", "roles": []}
#  responses:
#    200:
#      description: User avatar
###
GET           /:userId/avatar                             dev.pompilius.users.infrastructure.controllers.UserController.downloadAvatar(userId: String)

###
#  summary: Get user cover photo
#  roles: {"required": "none", "roles": []}
#  responses:
#    200:
#      description: User avatar
###
GET           /:userId/coverPhoto                             dev.pompilius.users.infrastructure.controllers.UserController.downloadCoverPhoto(userId: String)

###
#  summary: Register a new user
#  roles: {"required": "none", "roles": []}
#  requestBody:
#      required: true
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/RegisterUserRequest'
#  responses:
#    200:
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/User'
#      description: Registered user information
###
POST         /create                                      dev.pompilius.users.infrastructure.controllers.UserController.registerUser

###
#  summary: Update user info
#  roles: {"required": "any", "roles": ["ADMIN", "PROFESSIONAL", "AMATEUR", "STUDENT"]}
#  requestBody:
#      required: true
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/UpdateUserRequest'
#  responses:
#    200:
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/User'
#      description: Updated user information
###
PUT        /me                                    dev.pompilius.users.infrastructure.controllers.UserController.updateUser()

###
#  summary: Change user password
#  roles: {"required": "any", "roles": ["ADMIN", "PROFESSIONAL", "AMATEUR", "STUDENT"]}
#  requestBody:
#      required: true
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/ChangeUserPasswordRequest'
#  responses:
#    200:
#      description: Success
###
PUT       /me/password                               dev.pompilius.users.infrastructure.controllers.UserController.changePassword()

###
#  summary: Upload user avatar
#  roles: {"required": "any", "roles": ["ADMIN", "PROFESSIONAL", "AMATEUR", "STUDENT"]}
