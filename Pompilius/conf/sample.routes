#         $ref: '#/components/schemas/SampleResource'
#      description: Success
###
PUT          /:sampleId                                     dev.pompilius.sample.infrastructure.controllers.SampleController.update(sampleId: String)

###
#  summary: Get all sample by search criteria (name, type, rock type, freshness) and/or user ID
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  parameters:
#    - name: name
#      in: query
#      description: Name of the sample to search for (partial match)
#      required: false
#      schema:
#        type: string
#    - name: userId
#      in: query
#      description: ID of the user to retrieve studies for
#      required: false
#      schema:
#        type: string
#    - name: sampleType
#      in: query
#      description: Type of the sample (e.g., "sedimentary", "igneous", "metamorphic")
#      required: false
#      schema:
#        type: string
#    - name: rockType
#      in: query
#      description: Rock type of the sample (e.g., "granite", "limestone", "shale")
#      required: false
#      schema:
#        type: string
#    - name: isFresh
#      in: query
#      description: Whether the sample is fresh (true) or not (false)
#      required: false
#      schema:
#        type: boolean
#  responses:
#    200:
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/SampleList'
#      description: List of studies for the user  or all samples matching the search criteria
###
GET        /                                              dev.pompilius.sample.infrastructure.controllers.SampleController.getAll(name: Option[String], sampleType:Option[String], rockType: Option[String], isFresh:Option[Boolean], visibility: Option[String], localization: Option[String], userId: Option[String], pag: Pagination)

###
#  summary: Get a sample by ID
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  responses:
#    200:
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/SampleResource'
#      description: Sample information
#    404:
#      description: Sample not found
###
GET          /:sampleId                                     dev.pompilius.sample.infrastructure.controllers.SampleController.get(sampleId: String)

###
#  summary: Delete a sample (soft delete)
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL"]}
#  responses:
#    200:
#      description: Sample deleted successfully
#    404:
#      description: Sample not found
###
DELETE       /:sampleId                                     dev.pompilius.sample.infrastructure.controllers.SampleController.delete(sampleId: String)
