#      description: Success
###
POST         /create                                        dev.pompilius.sample.infrastructure.controllers.SampleController.create

###
#  summary: Update a sample
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL"]}
#  requestBody:
#      required: true
#      content:
#       application/json:
#        schema:
