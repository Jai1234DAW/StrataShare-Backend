#         type: object
###
GET          /summary                                  dev.pompilius.payment.infrastructure.controllers.PaymentController.getPaymentsSummary(paymentRole: String, fromDate: Option[String], toDate: Option[String])

###
#  summary: Get status for a specific payment
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  responses:
#    200:
#      description: Success
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/PaymentStatus'
###
GET        /:paymentId/status                            dev.pompilius.payment.infrastructure.controllers.PaymentController.getPaymentIntentStatus(paymentId: String)

###
#  summary: Get a specific payment by ID
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  responses:
#    200:
#      description: Success
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/Payment'
###
GET          /:paymentId                           dev.pompilius.payment.infrastructure.controllers.PaymentController.getPaymentById(paymentId: String)

