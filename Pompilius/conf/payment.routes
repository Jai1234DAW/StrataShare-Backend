###
POST         /create-intent                                 dev.pompilius.payment.infrastructure.controllers.PaymentController.createPaymentIntent()

###
#  summary: Get user payments
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  responses:
#    200:
#      description: Success
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/PaymentList'
###
GET         /                                              dev.pompilius.payment.infrastructure.controllers.PaymentController.getMyPaymentsAs(pag: Pagination, paymentRole)

###
#  summary: Get payment summary with optional date filtering
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  parameters:
#    - name: paymentRole
#      in: query
#      required: true
#      schema:
#        type: string
