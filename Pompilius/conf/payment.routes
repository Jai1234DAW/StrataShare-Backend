###
#  summary: Create a PaymentIntent for purchasing a resource
#  roles: {"required": "any", "roles": ["STUDENT","PROFESSIONAL","AMATEUR"]}
#  requestBody:
#      required: true
#      content:
#       application/json:
#        schema:
#         $ref: '#/components/schemas/CreatePaymentIntentRequest'
#  responses:
#    200:
#      description: Success
#      content:
#       application/json:
#        schema:
